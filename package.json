{
  "name": "localmail",
  "version": "1.0.0",
  "description": "Local SMTP mail catcher with web UI",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "generate-icons": "node scripts/generate-icons.js",
    "electron:dev": "npm run generate-icons && npm run build && electron .",
    "electron:build": "npm run generate-icons && npm run build && electron-builder",
    "electron:build:mac": "npm run generate-icons && npm run build && electron-builder --mac",
    "electron:build:win": "npm run generate-icons && npm run build && electron-builder --win",
    "electron:build:linux": "npm run generate-icons && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mailparser": "^3.6.5",
    "smtp-server": "^3.13.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.10.0",
    "@types/smtp-server": "^3.5.10",
    "@types/uuid": "^9.0.7",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "build": {
    "appId": "io.localmail.app",
    "productName": "LocalMail",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
